# PCO Legislation API key (https://api.legislation.govt.nz)
NZ_LEGISLATION_API_KEY=your-pco-api-key-here

# Login credentials shown on the /api/oauth/authorize page.
# These are what you'll type into the login screen when you connect from Claude.
#
# Two ways to configure logins (you can use either or both):
#
#   1) Single user — the legacy pair below:
MCP_USER=changeme
MCP_PASS=changeme
#
#   2) Multiple users — a JSON object of {"username": "password", ...}:
# MCP_USERS_JSON={"alice":"pw1","bob":"pw2"}
#
# Both sources are merged into one user map. On a username clash, MCP_USERS_JSON
# wins. If neither is set, every login is denied (fail closed). Malformed
# MCP_USERS_JSON is ignored and the single MCP_USER/MCP_PASS pair is used.
#
# The username typed at login becomes that request's identity (the "user" claim
# carried in the issued access token). Note: this connector currently has no
# separate allowlist — any user in the map can use all tools. If/when an
# allowlist env var is added, EVERY username here must also be added to it, or
# that user can sign in but every data tool will deny them.

# Secret used to sign OAuth JWTs (client IDs, auth codes, access tokens).
# Must be at least 32 characters. Generate with: `openssl rand -base64 48`.
OAUTH_SECRET=replace-with-at-least-32-chars-of-random

# Optional: pin the canonical issuer URL. If unset, the server uses VERCEL_URL
# in production, or the request's host header locally. Set this if your server
# is fronted by a custom domain.
# OAUTH_ISSUER=https://your-custom-domain.example.com
